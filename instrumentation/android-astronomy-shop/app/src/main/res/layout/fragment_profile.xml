<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

        <!-- Profile Header -->
        <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/design_default_color_primary"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="24dp">

                <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_person_24"
                        app:tint="@android:color/white" />

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Welcome, Astronomer!"
                        android:textColor="@android:color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Profile and Developer Tools"
                        android:textColor="@android:color/white"
                        android:textSize="14sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Regular Menu Options -->
        <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                <!-- ORDER HISTORY SECTION -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#E8F4FD">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Your Orders"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1976D2"
                            android:layout_marginBottom="8dp" />

                        <!-- Order History Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonOrderHistory"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:backgroundTint="#2196F3"
                            android:text="View Order History"
                            android:textColor="@android:color/white"
                            android:textSize="16sp"
                            app:icon="@drawable/ic_history_24"
                            app:iconTint="@android:color/white"
                            app:iconSize="24dp"
                            app:cornerRadius="12dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Account Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonAccount"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="Account"
                    android:textColor="@color/design_default_color_primary"
                    android:textSize="16sp"
                    app:icon="@drawable/ic_person_24"
                    app:iconTint="@color/design_default_color_primary"
                    app:iconSize="24dp"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/design_default_color_primary"
                    app:strokeWidth="1dp" />

                <!-- Settings Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonSettings"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="Settings"
                    android:textColor="@color/design_default_color_primary"
                    android:textSize="16sp"
                    app:icon="@drawable/ic_settings_24"
                    app:iconTint="@color/design_default_color_primary"
                    app:iconSize="24dp"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/design_default_color_primary"
                    app:strokeWidth="1dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- App Info -->
        <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AstronomyShop - Version 1.0 - Feb 2026"
                        android:textSize="16sp"
                        android:textStyle="bold" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>